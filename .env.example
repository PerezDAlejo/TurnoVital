# ===== CONFIGURACIÓN PRINCIPAL =====

# ===== CONFIGURACIÓN IA - ARQUITECTURA HÍBRIDA =====
# CHAT CONVERSACIONAL: Gemini 2.0 Flash (rápido, económico, 96% ahorro)
# OCR ÓRDENES MÉDICAS: GPT-4o Vision (precisión médica crítica, 86% probado)
# COSTO TOTAL: ~$77,500 COP/mes para 2500 pacientes (vs $650,000 solo GPT-4o)

# OpenAI Configuration (Solo para OCR Vision - órdenes médicas)
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o

# Gemini Configuration (Chat conversacional - principal)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_MODEL=gemini-2.0-flash-exp
USE_GEMINI=true

# Twilio WhatsApp Configuration (Testing con sandbox)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Secretaria Configuration (Escalamiento) - Solo 1 secretaria con sistema de cola
SECRETARY_WHATSAPP_TO=+573XXXXXXXXX
ADMIN_WHATSAPP=+573XXXXXXXXX

# Database Configuration (Supabase optimizada) - DESHABILITADA para testing inicial
DATABASE_URL=
TENANT_KEY=react

# Saludtools API Configuration (SANDBOX)
SALUDTOOLS_BASE_URL=https://saludtools.qa.carecloud.com.co/integration
SALUDTOOLS_API_KEY=XXXXXXXXXXXXXXXXXXXXXX
SALUDTOOLS_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SALUDTOOLS_CLINIC_ID=47576
SALUDTOOLS_DOCTOR_DOCUMENT_TYPE=1
SALUDTOOLS_DOCTOR_DOCUMENT_NUMBER=55223626
SALUDTOOLS_DEBUG=1

# Sistema Configuration (Optimizada)
ENVIRONMENT=sandbox
DEMO_MODE=false
API_DOCS_ENABLED=1
OCR_ENABLED=1
CALENDAR_ENABLED=0

# Escalamiento y Secretarias (Configuración IPS React)
SKIP_SELF_NOTIFICATION=false
HANDOFF_PERSISTENCE=1
NOTIFY_SECRETARIES=true
SECRETARY_CAPACITY=3
PRIMARY_CONTACT_NUMBER=+573XXXXXXXXX

# Monitoreo y Seguridad
SERVICE_MAX_FAILURES=3
HEALTH_CHECK_INTERVAL=30
AUTO_MONITORING_ENABLED=true
GOOGLE_CREDENTIALS_PATH=secrets/clinica-agendamiento-XXXXXXXX
